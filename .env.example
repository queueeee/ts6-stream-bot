# API key required to call control endpoints (POST /play etc.)
# REQUIRED. The app refuses to start with an empty or "changeme"-style placeholder.
# Generate one with: openssl rand -base64 32
BOT_API_KEY=

# Logging
LOG_LEVEL=INFO

# Display / capture (defaults are sane, only change if you know why)
DISPLAY=:99
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080
SCREEN_FPS=30

# PulseAudio
PULSE_SINK=bot_sink

# Apply ffmpeg loudnorm filter to normalize loudness across sources (true/false)
AUDIO_LOUDNORM=false

# --- TS6 connection ---------------------------------------------------------
# Used by phase 1+ once the native voice client is wired. Empty TS6_HOST means
# "no server configured" - the bot still starts and lets you render sources,
# but produces no output until you set these and finish the integration.
TS6_HOST=
TS6_PORT=9987
TS6_NICKNAME=ts6-stream-bot
TS6_SERVER_PASSWORD=
TS6_DEFAULT_CHANNEL=
TS6_CHANNEL_PASSWORD=

# --- TS3 identity persistence ----------------------------------------------
# Path inside the container to the JSON file backing the bot's TS3
# identity (P-256 keypair + hashcash offset). The default is mounted from
# the `bot-state` named volume defined in docker-compose.yml so that the
# identity survives container restarts. If you ever lose this file, the
# bot generates a new one on next start - which means the TS6 server
# treats it as a fresh client and previous stream slots may linger as
# zombies until the server's own cleanup kicks in.
# IDENTITY_PATH=/app/state/identity.json
#
# Hashcash level used to mine a *new* identity. Existing files are loaded
# as-is regardless of this value. 8 finishes in milliseconds; 20+ takes
# seconds; 24+ takes minutes. TS6 typically wants >= 8.
# IDENTITY_SECURITY_LEVEL=8

# --- Stream parameters -----------------------------------------------------
# These shape the `setupstream` request the bot sends after connecting.
# - STREAM_ACCESSIBILITY: 0 = public (anyone in the channel can join);
#   1 = restricted (requires explicit allow per viewer). 0 is what the
#   normal TS6 client UI sends for a screen share.
# - STREAM_MODE: 1 = request-based (server forwards notifyjoinstreamrequest
#   for each viewer and the bot replies via respondjoinstreamrequest);
#   0 = auto-accept.
# - STREAM_VIEWER_LIMIT: each viewer spins up its own VP8 encoder
#   (~280 MB RSS at 720p30) so unlimited can OOM a small host. The default
#   of 4 is conservative; bump it once you've measured memory under load.
#   -1 = unlimited (TS3 convention). 0 is interpreted by some TS6 builds
#   as "no viewers allowed", which silently drops every join attempt -
#   don't use 0.
# - STREAM_BITRATE: hint to the server (kbps); 4608 mirrors the default the
#   TS6 client uses for "high quality" screen share.
STREAM_BITRATE=4608
STREAM_ACCESSIBILITY=0
STREAM_MODE=1
STREAM_VIEWER_LIMIT=4

# --- WebRTC ICE servers ----------------------------------------------------
# STUN exposes the bot's public-NAT'd IP as a server-reflexive candidate;
# TURN relays media when direct NAT punching fails. The defaults work for
# most home setups. If your host is behind symmetric / CGNAT and viewers
# can't connect, point TURN_URL at a free relay (or your own coturn).
STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:openrelay.metered.ca:80
# TURN_USERNAME=openrelayproject
# TURN_PASSWORD=openrelayproject
