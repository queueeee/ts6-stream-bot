# API key required to call control endpoints (POST /play etc.)
# REQUIRED. The app refuses to start with an empty or "changeme"-style placeholder.
# Generate one with: openssl rand -base64 32
BOT_API_KEY=

# Logging
LOG_LEVEL=INFO

# Display / capture (defaults are sane, only change if you know why)
DISPLAY=:99
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080
SCREEN_FPS=30

# HLS encoding parameters
HLS_SEGMENT_DURATION=2
HLS_PLAYLIST_SIZE=6

# PulseAudio
PULSE_SINK=bot_sink

# Apply ffmpeg loudnorm filter to normalize loudness across sources (true/false).
AUDIO_LOUDNORM=false

# Default room name (used in HLS path: /stream/<room>/index.m3u8)
DEFAULT_ROOM=default
